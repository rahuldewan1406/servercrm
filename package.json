{
  "name": "nhai-crm",
  "version": "2.0.0",
  "description": "DIC-NHAI CRM Command Centre",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node api-server.js",
    "start:smtp": "node server.js",
    "start:dev": "node api-server.js & node server.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "stop:pm2": "pm2 stop ecosystem.config.js",
    "db:migrate": "node -e \"require('./server/db').init().then(()=>process.exit(0))\"",
    "health": "curl -s http://localhost:3002/health | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d)))\"",
    "logs": "pm2 logs nhai-crm-api"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "pm2": "^7.0.1"
  }
}
