# DIC-NHAI CRM — Environment Variables
# Copy this file to .env and fill in secure values before deploying

# REQUIRED in production — use a strong random string (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_MIN_32_CHARS

# Allowed CORS origin (the URL where the frontend is served)
ALLOWED_ORIGIN=http://localhost:8000

# Database file path (defaults to crm-data.json in project root)
# DB_PATH=/secure/path/to/crm-data.json

# Server port
PORT=3002
