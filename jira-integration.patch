+/* ══════════════════════════════════════════════════════
+   JIRA INTEGRATION
+══════════════════════════════════════════════════════ */
+
+/* Sync button */
+.jira-sync-btn {
+  background: #0052cc !important;
+  color: #fff !important;
+  border-color: #0052cc !important;
+}
+.jira-sync-btn:hover { background: #0747a6 !important; border-color: #0747a6 !important; }
+
+/* Jira panel */
+.jira-panel {
+  background: var(--surface);
+  border: 1.5px solid #0052cc33;
+  border-radius: 14px;
+  margin-bottom: 1.25rem;
+  overflow: hidden;
+  box-shadow: var(--shadow);
+}
+.jira-panel-header {
+  display: flex; align-items: center; justify-content: space-between;
+  padding: .85rem 1.1rem;
+  background: linear-gradient(135deg, #0052cc0a, #2684ff0a);
+  border-bottom: 1px solid #0052cc22;
+  flex-wrap: wrap; gap: .5rem;
+}
+.jira-panel-title {
+  font-weight: 700; font-size: .92rem; color: var(--text);
+  display: flex; align-items: center; gap: .5rem;
+}
+.jira-project-key {
+  background: #0052cc; color: #fff;
+  padding: 2px 8px; border-radius: 4px;
+  font-size: .72rem; font-weight: 700; font-family: var(--mono);
+}
+.jira-panel-actions { display: flex; gap: .4rem; align-items: center; flex-wrap: wrap; }
+.jira-search {
+  border: 1px solid var(--border); border-radius: 7px;
+  padding: .35rem .65rem; font-size: .8rem; background: var(--surface);
+  width: 180px;
+}
+
+/* Issue list */
+.jira-issue-list { max-height: 420px; overflow-y: auto; }
+.jira-empty { padding: 2rem; text-align: center; color: var(--text-3); font-size: .85rem; }
+
+/* Issue row */
+.jira-issue-row {
+  display: grid;
+  grid-template-columns: 1.2rem 90px 1fr 120px 100px 90px 80px auto;
+  gap: .5rem; align-items: center;
+  padding: .55rem 1.1rem;
+  border-bottom: 1px solid var(--border);
+  font-size: .8rem; transition: background .12s; cursor: pointer;
+}
+.jira-issue-row:hover { background: #f0f7ff; }
+.jira-issue-row:last-child { border-bottom: none; }
+.jira-issue-head {
+  background: var(--bg); font-size: .7rem; font-weight: 700;
+  text-transform: uppercase; letter-spacing: .05em; color: var(--text-3);
+  cursor: default;
+}
+.jira-issue-head:hover { background: var(--bg); }
+
+/* Issue key */
+.jira-issue-key {
+  font-family: var(--mono); font-weight: 700; font-size: .75rem;
+  color: #0052cc; text-decoration: none; white-space: nowrap;
+}
+.jira-issue-key:hover { text-decoration: underline; }
+
+/* Issue type icon */
+.jira-type-icon { font-size: .9rem; }
+
+/* Summary */
+.jira-issue-summary { font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
+
+/* Status chips */
+.jira-status-chip {
+  padding: 2px 8px; border-radius: 20px;
+  font-size: .68rem; font-weight: 700; white-space: nowrap;
+  display: inline-block;
+}
+.jira-todo       { background: #dfe1e6; color: #42526e; }
+.jira-inprogress { background: #deebff; color: #0052cc; }
+.jira-inreview   { background: #e3fcef; color: #006644; }
+.jira-done       { background: #e3fcef; color: #006644; }
+.jira-blocked    { background: #ffebe6; color: #bf2600; }
+.jira-open       { background: #fffae6; color: #974f0c; }
+
+/* Priority */
+.jira-priority { display: flex; align-items: center; gap: .25rem; font-size: .75rem; }
+.jira-prio-highest { color: #bf2600; }
+.jira-prio-high    { color: #ff5630; }
+.jira-prio-medium  { color: #ff8b00; }
+.jira-prio-low     { color: #2684ff; }
+.jira-prio-lowest  { color: #2684ff; }
+
+/* Assignee */
+.jira-assignee {
+  display: flex; align-items: center; gap: .3rem;
+  font-size: .75rem; color: var(--text-2);
+}
+.jira-assignee-avatar {
+  width: 20px; height: 20px; border-radius: 50%;
+  display: flex; align-items: center; justify-content: center;
+  font-size: .6rem; font-weight: 700; color: #fff; flex-shrink: 0;
+}
+
+/* Action buttons */
+.jira-row-btn {
+  background: none; border: 1px solid var(--border);
+  border-radius: 5px; padding: 2px 6px; font-size: .7rem;
+  cursor: pointer; color: var(--text-2); transition: all .12s;
+  white-space: nowrap;
+}
+.jira-row-btn:hover { background: #eff6ff; border-color: #93c5fd; color: var(--accent); }
+
+/* Jira stats bar */
+.jira-stats {
+  display: flex; gap: .5rem; flex-wrap: wrap;
+  padding: .6rem 1.1rem;
+  background: var(--bg); border-top: 1px solid var(--border);
+  font-size: .75rem;
+}
+.jira-stat { color: var(--text-2); }
+.jira-stat strong { color: var(--text); }
+
+/* Config modal tabs */
+.jira-config-tabs { display: flex; gap: .3rem; margin-bottom: 1rem; }
+.jira-ctab {
+  background: var(--bg); border: 1px solid var(--border);
+  border-radius: 7px; padding: .4rem .85rem;
+  font-size: .8rem; font-weight: 600; cursor: pointer;
+  color: var(--text-2); transition: all .15s;
+}
+.jira-ctab.active { background: #0052cc; color: #fff; border-color: #0052cc; }
+.jira-config-content { animation: fadeIn .2s; }
+.jira-config-info {
+  background: #eff6ff; border: 1px solid #bfdbfe;
+  border-radius: 8px; padding: .65rem .85rem;
+  font-size: .8rem; color: #1e40af; margin-bottom: .85rem;
+}
+
+/* Status mapping */
+.jira-status-mapping { display: flex; flex-direction: column; gap: .4rem; margin-top: .4rem; }
+.jira-map-row { display: flex; align-items: center; gap: .5rem; font-size: .8rem; }
+
+/* Issue detail modal */
+.jira-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem .75rem; margin-bottom: 1rem; }
+.jira-detail-item { font-size: .82rem; }
+.jira-detail-key { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--text-3); margin-bottom: 2px; }
+.jira-detail-val { color: var(--text); font-weight: 500; }
+.jira-detail-desc { background: var(--bg); border-radius: 8px; padding: .65rem; font-size: .82rem; line-height: 1.6; color: var(--text-2); margin-bottom: .75rem; }
+
+/* Linked task badge */
+.jira-linked-badge {
+  display: inline-flex; align-items: center; gap: .3rem;
+  background: #dcfce7; color: #15803d;
+  padding: 3px 10px; border-radius: 20px; font-size: .73rem; font-weight: 600;
+}
